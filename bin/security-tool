#!/bin/bash

################################################################################
# XecuBash - Herramienta de Ciberseguridad para Debian 13 Trixie
# Punto de entrada principal
################################################################################

set -euo pipefail

# Variables globales
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
MODULES_DIR="${PROJECT_ROOT}/modules"
CONFIG_DIR="${PROJECT_ROOT}/config"
UTILS_DIR="${PROJECT_ROOT}/utils"
LOGS_DIR="${PROJECT_ROOT}/logs"
BACKUPS_DIR="${PROJECT_ROOT}/backups"
VERSION="1.0.0"
APP_NAME="XecuBash"

# Crear directorios si no existen
mkdir -p "$LOGS_DIR" "$BACKUPS_DIR"

# Importar utilidades
source "${UTILS_DIR}/logger.sh"
source "${UTILS_DIR}/validator.sh"
source "${UTILS_DIR}/snapshots.sh"

# Mostrar banner
show_banner() {
    cat << "EOF"
╔═══════════════════════════════════════════════════════════════╗
║                                                               ║
║         XecuBash v1.0.0 - Security Tool for Debian 13        ║
║                                                               ║
║              Herramienta de Ciberseguridad Integral           ║
║                                                               ║
╚═══════════════════════════════════════════════════════════════╝
EOF
}

# Función de ayuda
show_help() {
    cat << "EOF"
USO: security-tool [COMANDO] [OPCIONES]

COMONDOS PRINCIPALES:
  audit              Ejecutar auditoría de seguridad completa
  harden             Aplicar hardening del sistema
  network            Configurar seguridad de red
  dnscrypt           Configurar DNS encriptado
  anonymity          Configurar anonimato (Tor, VPN, proxys)
  firewall           Configurar firewall (ufw/iptables)
  identifiers        Gestionar MAC, IP, IPv6, hostname
  report             Generar reportes de seguridad
  revert             Revertir cambios previos

OPCIONES GLOBALES:
  --help             Mostrar esta ayuda
  --version          Mostrar versión
  --dry-run          Mostrar cambios sin aplicar
  --apply            Aplicar cambios de seguridad
  --log-level LEVEL  Nivel de logging (DEBUG, INFO, WARN, ERROR)
  --config FILE      Usar archivo de configuración personalizado
  --no-backup        Omitir backup automático

EJEMPLOS:
  sudo ./security-tool audit --dry-run
  sudo ./security-tool harden --apply
  sudo ./security-tool report --format html --output report.html
  sudo ./security-tool dnscrypt --setup

Para más información: man security-tool
EOF
}

# Verificar permisos de root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Este script debe ejecutarse como root o con sudo"
        exit 1
    fi
}

# Menú interactivo principal
show_menu() {
    clear
    show_banner
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "                    MENÚ PRINCIPAL"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    echo "1. Auditoría de Seguridad Completa"
    echo "2. Hardening del Sistema Base"
    echo "3. Seguridad de Red"
    echo "4. Configurar DNSCrypt"
    echo "5. Configurar Anonimato (Tor/VPN/Proxys)"
    echo "6. Configurar Firewall"
    echo "7. Gestionar Identificadores (MAC/IP/IPv6)"
    echo "8. Generar Reporte de Seguridad"
    echo "9. Revertir Cambios Previos"
    echo "10. Salir"
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
}

# Procesar comando principal
process_command() {
    local cmd="${1:-}"
    shift || true
    local options="$@"

    log_info "Iniciando comando: $cmd"

    case "$cmd" in
        audit)
            log_info "Ejecutando auditoría de seguridad..."
            source "${MODULES_DIR}/audit.sh"
            audit_main $options
            ;;
        harden)
            log_info "Iniciando hardening del sistema..."
            create_snapshot "Antes de hardening"
            source "${MODULES_DIR}/system-hardening.sh"
            harden_main $options
            ;;
        network)
            log_info "Configurando seguridad de red..."
            create_snapshot "Antes de cambios de red"
            source "${MODULES_DIR}/network-security.sh"
            network_security_main $options
            ;;
        dnscrypt)
            log_info "Configurando DNSCrypt..."
            create_snapshot "Antes de configurar DNSCrypt"
            source "${MODULES_DIR}/dnscrypt-setup.sh"
            dnscrypt_main $options
            ;;
        anonymity)
            log_info "Configurando anonimato..."
            create_snapshot "Antes de anonimato"
            source "${MODULES_DIR}/anonymity.sh"
            anonymity_main $options
            ;;
        firewall)
            log_info "Configurando firewall..."
            create_snapshot "Antes de firewall"
            source "${MODULES_DIR}/firewall-rules.sh"
            firewall_main $options
            ;;
        identifiers)
            log_info "Gestionando identificadores..."
            create_snapshot "Antes de cambiar identificadores"
            source "${MODULES_DIR}/identifiers.sh"
            identifiers_main $options
            ;;
        report)
            log_info "Generando reporte..."
            source "${MODULES_DIR}/reporting.sh"
            reporting_main $options
            ;;
        revert)
            log_info "Revirtiendo cambios..."
            source "${UTILS_DIR}/snapshots.sh"
            revert_changes $options
            ;;
        --help|-h|help)
            show_help
            ;;
        --version|-v)
            echo "XecuBash v$VERSION"
            ;;
        "")
            # Modo menú interactivo
            check_root
            interactive_mode
            ;;
        *)
            log_error "Comando desconocido: $cmd"
            show_help
            exit 1
            ;;
    esac
}

# Modo interactivo
interactive_mode() {
    while true; do
        show_menu
        read -p "Selecciona una opción (1-10): " choice
        
        case $choice in
            1) source "${MODULES_DIR}/audit.sh" && audit_main ;;
            2) create_snapshot "Antes de hardening" && source "${MODULES_DIR}/system-hardening.sh" && harden_main ;;
            3) create_snapshot "Antes de cambios de red" && source "${MODULES_DIR}/network-security.sh" && network_security_main ;;
            4) create_snapshot "Antes de DNSCrypt" && source "${MODULES_DIR}/dnscrypt-setup.sh" && dnscrypt_main ;;
            5) create_snapshot "Antes de anonimato" && source "${MODULES_DIR}/anonymity.sh" && anonymity_main ;;
            6) create_snapshot "Antes de firewall" && source "${MODULES_DIR}/firewall-rules.sh" && firewall_main ;;
            7) create_snapshot "Antes de identificadores" && source "${MODULES_DIR}/identifiers.sh" && identifiers_main ;;
            8) source "${MODULES_DIR}/reporting.sh" && reporting_main ;;
            9) source "${UTILS_DIR}/snapshots.sh" && revert_changes ;;
            10) log_info "Saliendo..."; exit 0 ;;
            *) log_error "Opción inválida. Intenta de nuevo." ;;
        esac
        
        read -p "Presiona Enter para continuar..."
    done
}

# Script principal
main() {
    # Verificar si es root (excepto para --help y --version)
    if [[ "${1:-}" != "--help" && "${1:-}" != "-h" && "${1:-}" != "help" && 
          "${1:-}" != "--version" && "${1:-}" != "-v" ]]; then
        check_root
    fi

    process_command "$@"
}

# Ejecutar
main "$@"
